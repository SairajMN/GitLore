# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitlore:gitlore@localhost:5432/gitlore
DATABASE_URL_SYNC=postgresql://gitlore:gitlore@localhost:5432/gitlore

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── GitHub ───────────────────────────────────────────────────────
# Personal access token with repo scope for fetching private repos
GITHUB_TOKEN=

# ─── LLM Providers ────────────────────────────────────────────────
# Groq (fastest, cheapest — used for classification and summarization)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter (broad model access — used for answer synthesis)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Inception Labs (specialized models)
INCEPTION_API_KEY=
INCEPTION_BASE_URL=https://api.inception.ai/v1

# ─── Model Routing ────────────────────────────────────────────────
# Format: provider:model_name
MODEL_QUERY_CLASSIFICATION=groq:llama-3.1-8b-instant
MODEL_EVIDENCE_SUMMARIZATION=groq:llama-3.1-8b-instant
MODEL_ANSWER_SYNTHESIS=openrouter:meta-llama/llama-3.1-70b-instruct
MODEL_EMBEDDING=openrouter:text-embedding-3-small

# ─── Frontend (Next.js) ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── App ──────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
